{
    "name": "p3k/compass",
    "description": "Compass is a GPS tracking server that stores data in flat files.",
    "keywords": ["p3k", "gps"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "laravel/lumen-framework": "^11.0",
        "vlucas/phpdotenv": "^5.6",
        "p3k/quartz-db": "0.1.*",
        "indieauth/client": "^0.2 || ^0.3 || ^1.0",
        "guzzlehttp/guzzle":"^7.8",
        "illuminate/redis": "^11.0",
        "p3k/multipart": "*",
        "p3k/utils": ">=1.1.1",
        "p3k/timezone": "^0.1.0",
        "illuminate/cookie": "^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "config": {
        "preferred-install": "dist"
    }
}
